# Copy to .env (gitignored) and fill in. The engines auto-load this file from
# the repo root. NEVER commit .env. Use PAPER/data keys here — the live
# trading key belongs only in the live/ process environment (constitution
# rule 3), and real trading additionally needs QP_REAL_TRADING=1 + --real +
# environment="real" in guardrails.toml.

# --- Alpaca (paper + market data; IEX daily bars) ---
# From https://app.alpaca.markets/  →  Paper account → API keys.
ALPACA_API_KEY=PK...your_paper_key...
ALPACA_SECRET_KEY=...your_paper_secret...

# --- Telegram control bridge ---
# Bot token from @BotFather; owner id (a NUMBER) from @userinfobot.
TELEGRAM_BOT_TOKEN=123456:ABC...your_bot_token...
TELEGRAM_OWNER_ID=777000111

# --- Real-money gate (leave UNSET for paper/dry-run) ---
# Only set to 1 when you truly intend real orders, alongside --real and
# environment="real" in live/guardrails.toml. Unset = safe.
# QP_REAL_TRADING=1
